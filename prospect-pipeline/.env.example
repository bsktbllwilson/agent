# =============================================================================
# Trigger sources
# =============================================================================
# Socrata app token — free at https://opendata.cityofnewyork.us/profile/app_tokens
# Unauthenticated requests are throttled; add a token for higher limits.
SOCRATA_APP_TOKEN=

# UrbanDigs — paid API, contract-signed leading indicator for Manhattan.
# If not provisioned, leave URBANDIGS_ENABLED=false and the pipeline will skip.
URBANDIGS_API_KEY=
URBANDIGS_BASE_URL=
URBANDIGS_ENABLED=false

# =============================================================================
# Buyer resolution
# =============================================================================
# Marketproof — beneficial ownership + co-op buyer coverage (paid)
MARKETPROOF_API_KEY=
MARKETPROOF_BASE_URL=https://api.marketproof.com/v1

# PropertyShark — BBL filings, owner corrections, linked entities (paid)
PROPERTYSHARK_API_KEY=
PROPERTYSHARK_BASE_URL=https://api.propertyshark.com/v1

# =============================================================================
# Contact enrichment
# =============================================================================
# Clay orchestrates a waterfall (Apollo / ZoomInfo / Hunter / LinkedIn SN / Findymail)
CLAY_API_KEY=
CLAY_WORKSPACE_ID=

# =============================================================================
# Classification
# =============================================================================
ANTHROPIC_API_KEY=
BUYER_CLASSIFICATION_MODEL=claude-opus-4-7

# =============================================================================
# CRM (optional — only needed if running `push-to-crm`)
# =============================================================================
HUBSPOT_API_KEY=
SALESFORCE_CREDS=

# =============================================================================
# Scraping posture
# =============================================================================
# User-Agent MUST include a contact email so publishers can reach us.
SCRAPER_USER_AGENT=AlignmentRE-ResearchBot/1.0 (contact@alignmentre.com)
ENABLE_PRESS_SCRAPER=true

# =============================================================================
# Suppression + delivery
# =============================================================================
OUTREACH_SUPPRESSION_DAYS=90

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_RECIPIENT=

# =============================================================================
# Local paths / behavior
# =============================================================================
PIPELINE_DB_PATH=prospect_pipeline.db
PIPELINE_OUTPUT_DIR=./out
PIPELINE_LOG_DIR=./logs
