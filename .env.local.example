# Copy to .env.local and fill in. Also set these in Vercel → Settings →
# Environment Variables (Production + Preview).

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — enables emailing sellers on approve/reject and any
# other server-side admin lookups. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — resend.com → API keys
RESEND_API_KEY=

# Transactional email config
# EMAIL_FROM must be a verified sender on a verified domain in Resend.
EMAIL_FROM="Pass The Plate <deals@passtheplate.store>"
# ADMIN_EMAIL receives new-submission + new-inquiry notifications.
ADMIN_EMAIL=

# Site URL used in email CTA links (and metadata fallback).
NEXT_PUBLIC_SITE_URL=https://passtheplate.store
