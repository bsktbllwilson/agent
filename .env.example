# No environment variables required to run the app locally.
# The app works out of the box with seed data and localStorage.

# --- Optional integrations ---

# Airtable (connects to your BridgeEast base for live neighborhood data)
# AIRTABLE_PAT=pat...
# AIRTABLE_BASE_ID=appAF9PYz7hHq5AIM
# AIRTABLE_TABLE_ID=tblPZcv6xjl4o6PAp

# Yelp Fusion API (live Asian restaurant counts per neighborhood)
# Get a key at: https://www.yelp.com/developers/v3/manage_app
# YELP_API_KEY=your-yelp-api-key

# Supabase (if upgrading from localStorage to a real database)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
